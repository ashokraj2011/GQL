{
  "evaluation_group": {
    "id": "1",
    "namespace": "customerPlans",
    "datasource": "CASGraphQL",
    "record_selector": {
      "pre_filter": { ... },
      "order_by": [ ... ],
      "pick": {
        "mode": "first | last | limit | range",
        "count": 5,
        "fromRecord": 1,
        "toRecord": 10
      }
    }
